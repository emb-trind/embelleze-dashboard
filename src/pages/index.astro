---
import {
  getOwnerSummary,
  getFunnelStats,
  getSourceStats,
  getStalledLeads,
  fetchFollowupLeads,
  countFollowupByStatus,
} from '../lib/db';
import { getLocationStats } from '../lib/redis';

const [legacySummary, legacyFunnel, legacySources, legacyStalled, geo, followupCounts, followupLeads] = await Promise.all([
  getOwnerSummary(),
  getFunnelStats(),
  getSourceStats(),
  getStalledLeads(),
  getLocationStats(),
  countFollowupByStatus(),
  fetchFollowupLeads(),
]);

const hasFollowup = followupLeads.length > 0;

const summary = hasFollowup
  ? {
      total: followupLeads.length,
      movimentados_hoje: followupLeads.filter((l) => (l.attempt_count ?? 0) > 0).length,
      novo: followupCounts['novo'] ?? 0,
      qualificado: 0,
      interessado: followupCounts['contato'] ?? 0,
      pix_gerado: 0,
      pix_pago: followupCounts['matricula'] ?? 0,
    }
  : legacySummary;

const funnel = hasFollowup
  ? [
      { status: 'novo', label: 'Novos', count: followupCounts['novo'] ?? 0, percent: 0 },
      { status: 'contato', label: 'Interessados', count: followupCounts['contato'] ?? 0, percent: 0 },
      { status: 'matricula', label: 'Pagos', count: followupCounts['matricula'] ?? 0, percent: 0 },
    ].map((step, _, arr) => {
      const max = Math.max(...arr.map((s) => s.count), 1);
      return { ...step, percent: Math.round((step.count / max) * 100) };
    })
  : legacyFunnel;

const sources = hasFollowup
  ? Array.from(
      followupLeads.reduce((acc, lead) => {
        const key = lead.source_canon || 'unknown_origem';
        const current = acc.get(key) || { fonte: key, total: 0, matriculas: 0, conversoes: 0, taxa: 0 };
        current.total += 1;
        if (lead.status_canon === 'matricula') {
          current.matriculas += 1;
          current.conversoes += 1;
        } else if (lead.status_canon === 'contato') {
          current.conversoes += 1;
        }
        acc.set(key, current);
        return acc;
      }, new Map<string, { fonte: string; total: number; matriculas: number; conversoes: number; taxa: number }>())
        .values(),
    )
      .map((item) => ({
        ...item,
        taxa: item.total > 0 ? Math.round((item.matriculas / item.total) * 100) : 0,
      }))
      .sort((a, b) => b.total - a.total)
      .slice(0, 10)
  : legacySources;

const stalled = hasFollowup
  ? followupLeads
      .filter((lead) => lead.status_canon === 'contato' && lead.whatsapp_state !== 'replied')
      .slice(0, 20)
      .map((lead) => ({
        phone: lead.phone_e164.replace(/^\+55/, ''),
        name: lead.name,
        status: lead.status_canon,
        updated_at: lead.next_action_at || new Date().toISOString(),
        horas_parado: 48,
      }))
  : legacyStalled;

const taxaConversao = summary.total > 0
  ? ((summary.pix_pago / summary.total) * 100).toFixed(1)
  : '0.0';

const FUNNEL_COLOR: Record<string, string> = {
  'Novos':        '#a78bca',
  'Qualificados': '#5f3080',
  'Interessados': '#de583d',
  'Pix Gerado':   '#f59e0b',
  'Pagos':        '#22c55e',
};
---
<!doctype html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
  <meta name="mobile-web-app-capable" content="yes" />
  <meta name="apple-mobile-web-app-status-bar-style" content="default" />
  <meta name="apple-mobile-web-app-title" content="Painel" />
  <meta name="theme-color" content="#f0f4ff" />
  <link rel="manifest" href="/manifest.json" />
  <link rel="apple-touch-icon" href="/brand/avatar_e-trindade.png" />
  <title>Painel · Embelleze</title>
  <script>
    // Registra SW apenas em HTTPS ou localhost — nunca expõe dados em cache
    if ('serviceWorker' in navigator) {
      navigator.serviceWorker.register('/sw.js', { scope: '/' });
    }
  </script>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --bg:        #eef1f8;
      --bg2:       #e4e8f4;
      --glass:     rgba(255,255,255,0.72);
      --glass2:    rgba(255,255,255,0.52);
      --border:    rgba(255,255,255,0.9);
      --border2:   rgba(200,210,240,0.6);
      --purple:    #5f3080;
      --orange:    #de583d;
      --green:     #22c55e;
      --text:      #1a1030;
      --muted:     #7b6fa0;
      --nav-h:     76px;
      --safe-b:    env(safe-area-inset-bottom, 0px);
    }

    html, body {
      height: 100%;
      height: 100dvh;
      overflow: hidden;
      font-family: -apple-system, BlinkMacSystemFont, 'SF Pro Display', 'Segoe UI', sans-serif;
      background: var(--bg);
      color: var(--text);
      -webkit-font-smoothing: antialiased;
    }

    /* ── Desktop: centraliza como app mobile ── */
    @media (min-width: 600px) {
      body {
        background: #d8dce8;
        display: flex;
        align-items: center;
        justify-content: center;
      }
    }

    /* ── Layout raiz — tudo em 100dvh ── */
    .shell {
      height: 100dvh;
      display: flex;
      flex-direction: column;
      position: relative;
      overflow: hidden;
    }

    @media (min-width: 600px) {
      .shell {
        width: 430px;
        height: 100dvh;
        max-height: 932px;
        border-radius: 40px;
        box-shadow: 0 32px 80px rgba(0,0,0,0.22), 0 0 0 1px rgba(255,255,255,0.4);
        overflow: hidden;
      }
    }

    /* ── Fundo gradiente suave ── */
    .shell::before {
      content: '';
      position: fixed;
      inset: 0;
      background:
        radial-gradient(ellipse 80% 50% at 20% 0%, rgba(95,48,128,.12) 0%, transparent 60%),
        radial-gradient(ellipse 60% 40% at 80% 100%, rgba(222,88,61,.08) 0%, transparent 55%),
        linear-gradient(160deg, #eef1f8 0%, #e8ecf8 100%);
      z-index: 0;
      pointer-events: none;
    }

    /* ── Header compacto ── */
    .topbar {
      position: relative;
      z-index: 10;
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: calc(env(safe-area-inset-top, 0px) + 14px) 20px 12px;
      background: rgba(238,241,248,0.8);
      backdrop-filter: blur(20px);
      -webkit-backdrop-filter: blur(20px);
      border-bottom: 1px solid var(--border2);
    }
    .topbar__left { display: flex; align-items: center; gap: 10px; }
    .topbar__avatar {
      width: 32px; height: 32px; border-radius: 50%;
      object-fit: cover;
      box-shadow: 0 2px 8px rgba(95,48,128,.25);
    }
    .topbar__name {
      font-size: 16px; font-weight: 700;
      color: var(--text);
      letter-spacing: -0.3px;
      line-height: 1.1;
    }
    .topbar__badge {
      background: rgba(95,48,128,.12);
      color: var(--purple);
      font-size: 9px;
      font-weight: 700;
      padding: 2px 7px;
      border-radius: 100px;
      letter-spacing: 0.05em;
      text-transform: uppercase;
    }
    .topbar__logo {
      height: 28px;
      width: auto;
      object-fit: contain;
      opacity: .85;
    }
    .topbar__logout {
      width: 32px; height: 32px;
      border-radius: 50%;
      background: var(--glass2);
      border: 1px solid var(--border2);
      display: flex; align-items: center; justify-content: center;
      color: var(--muted);
      text-decoration: none;
      font-size: 14px;
      backdrop-filter: blur(10px);
    }

    /* ── Views (scroll interno só aqui) ── */
    .views {
      flex: 1;
      position: relative;
      z-index: 1;
      overflow: hidden;
    }

    .view {
      position: absolute;
      inset: 0;
      overflow-y: auto;
      padding: 16px 16px calc(var(--nav-h) + var(--safe-b) + 16px);
      display: none;
      -webkit-overflow-scrolling: touch;
    }
    .view.active { display: block; }

    /* ── Cards glassmorphism ── */
    .glass-card {
      background: var(--glass);
      backdrop-filter: blur(20px);
      -webkit-backdrop-filter: blur(20px);
      border: 1px solid var(--border);
      border-radius: 20px;
      box-shadow: 0 4px 24px rgba(95,48,128,.07), 0 1px 0 rgba(255,255,255,.9) inset;
    }

    /* ── KPI Grid ── */
    .kpi-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 10px;
      margin-bottom: 12px;
    }
    .kpi {
      padding: 16px;
    }
    .kpi__num {
      font-size: 36px;
      font-weight: 800;
      line-height: 1;
      letter-spacing: -1px;
      color: var(--text);
    }
    .kpi__num--orange { color: var(--orange); }
    .kpi__num--green  { color: var(--green); }
    .kpi__num--purple { color: var(--purple); }
    .kpi__label {
      font-size: 11px; font-weight: 600;
      color: var(--muted);
      text-transform: uppercase;
      letter-spacing: 0.06em;
      margin-top: 6px;
    }
    .kpi__sub { font-size: 11px; color: var(--muted); margin-top: 2px; }

    /* ── Seção title ── */
    .sec-title {
      font-size: 13px; font-weight: 700;
      color: var(--muted);
      text-transform: uppercase;
      letter-spacing: 0.08em;
      margin: 16px 0 8px 4px;
    }

    /* ── Funil ── */
    .funnel-wrap { padding: 16px; }
    .funnel-row {
      display: flex; align-items: center; gap: 10px;
      margin-bottom: 10px;
    }
    .funnel-row:last-child { margin-bottom: 0; }
    .funnel-lbl { font-size: 12px; color: var(--muted); width: 82px; flex-shrink: 0; }
    .funnel-track {
      flex: 1; height: 8px;
      background: rgba(95,48,128,.08);
      border-radius: 100px; overflow: hidden;
    }
    .funnel-bar { height: 100%; border-radius: 100px; min-width: 4px; }
    .funnel-num { font-size: 13px; font-weight: 700; color: var(--text); width: 22px; text-align: right; flex-shrink: 0; }

    /* ── Alerta parados ── */
    .alert-card {
      background: rgba(222,88,61,.08);
      border: 1px solid rgba(222,88,61,.2);
      border-radius: 16px;
      overflow: hidden;
      margin-bottom: 12px;
    }
    .alert-head {
      padding: 10px 14px;
      font-size: 12px; font-weight: 700;
      color: var(--orange);
    }
    .stall-row {
      display: flex; align-items: center; gap: 10px;
      padding: 10px 14px;
      border-top: 1px solid rgba(222,88,61,.1);
    }
    .stall-info { flex: 1; min-width: 0; }
    .stall-name { font-size: 13px; font-weight: 600; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
    .stall-meta { font-size: 11px; color: var(--muted); margin-top: 2px; }
    .stall-time { font-size: 11px; color: var(--orange); white-space: nowrap; }
    .wa-btn { background: #25d366; color: #fff; border-radius: 8px; padding: 6px 10px; font-size: 11px; font-weight: 700; text-decoration: none; flex-shrink: 0; }

    /* ── Geo ── */
    .geo-grid {
      display: grid; grid-template-columns: 1fr 1fr;
      gap: 10px; margin-bottom: 12px;
    }
    .geo-kpi { padding: 14px; }
    .geo-kpi__num { font-size: 28px; font-weight: 800; letter-spacing: -0.5px; }
    .geo-kpi__lbl { font-size: 10px; font-weight: 600; color: var(--muted); text-transform: uppercase; letter-spacing: 0.06em; margin-top: 4px; }
    .geo-kpi__sub { font-size: 10px; color: var(--muted); margin-top: 2px; }

    /* Bar chart geo */
    .bar-chart-wrap { padding: 14px 14px 10px; }
    .chart-lbl { font-size: 10px; font-weight: 700; color: var(--muted); text-transform: uppercase; letter-spacing: 0.07em; margin-bottom: 10px; }
    .bar-chart { display: flex; align-items: flex-end; gap: 5px; height: 60px; }
    .bar-col { flex: 1; display: flex; flex-direction: column; align-items: center; gap: 2px; height: 100%; }
    .bar-val { font-size: 9px; font-weight: 700; color: var(--purple); min-height: 12px; }
    .bar-track { flex: 1; width: 100%; background: rgba(95,48,128,.08); border-radius: 4px 4px 2px 2px; display: flex; align-items: flex-end; overflow: hidden; }
    .bar-fill { width: 100%; background: linear-gradient(180deg, var(--orange) 0%, var(--purple) 100%); border-radius: 4px 4px 0 0; min-height: 3px; }
    .bar-lbl { font-size: 8px; color: var(--muted); text-align: center; line-height: 1.2; white-space: nowrap; }

    /* Bairros */
    .bairros-wrap { padding: 0 14px 14px; }
    .bairro-row { display: flex; align-items: center; gap: 8px; margin-bottom: 8px; }
    .bairro-row:last-child { margin-bottom: 0; }
    .bairro-lbl { font-size: 11px; color: var(--muted); width: 90px; flex-shrink: 0; }
    .bairro-track { flex: 1; height: 6px; background: rgba(95,48,128,.08); border-radius: 100px; overflow: hidden; }
    .bairro-fill { height: 100%; background: var(--purple); border-radius: 100px; }
    .bairro-num { font-size: 11px; font-weight: 700; color: var(--text); width: 20px; text-align: right; }

    /* ── Meta view ── */
    .meta-hero {
      display: flex; align-items: center; gap: 16px;
      padding: 20px;
      margin-bottom: 12px;
      background: linear-gradient(135deg, rgba(6,104,225,.06) 0%, rgba(174,62,201,.06) 50%, rgba(250,56,62,.06) 100%);
      border: 1px solid rgba(174,62,201,.2);
    }
    .meta-hero__icon {
      width: 64px; height: 64px;
      background: rgba(255,255,255,.8);
      border-radius: 18px;
      display: flex; align-items: center; justify-content: center;
      flex-shrink: 0;
      box-shadow: 0 4px 16px rgba(174,62,201,.15);
    }
    .meta-hero__title {
      font-size: 18px; font-weight: 800;
      letter-spacing: -0.4px;
      color: var(--text);
    }
    .meta-hero__status {
      display: inline-flex; align-items: center; gap: 5px;
      margin-top: 5px;
      font-size: 11px; font-weight: 600;
      color: #7c3aed;
      background: rgba(124,58,237,.1);
      padding: 3px 10px;
      border-radius: 100px;
    }
    .meta-hero__status::before {
      content: '';
      width: 6px; height: 6px;
      border-radius: 50%;
      background: #7c3aed;
      animation: pulse-dot 2s infinite;
    }
    @keyframes pulse-dot {
      0%,100% { opacity: 1; }
      50% { opacity: .3; }
    }
    .meta-coming {
      background: var(--glass);
      backdrop-filter: blur(20px);
      -webkit-backdrop-filter: blur(20px);
      border: 1px solid var(--border);
      border-radius: 20px;
      padding: 28px 20px;
      text-align: center;
      box-shadow: 0 4px 24px rgba(95,48,128,.07);
    }
    .meta-coming__icon { font-size: 36px; margin-bottom: 12px; }
    .meta-coming__title { font-size: 16px; font-weight: 700; color: var(--text); margin-bottom: 8px; }
    .meta-coming__desc { font-size: 13px; color: var(--muted); line-height: 1.6; margin-bottom: 20px; }
    .meta-chips { display: flex; flex-wrap: wrap; gap: 6px; justify-content: center; }
    .meta-chip {
      font-size: 11px; font-weight: 600;
      color: var(--purple);
      background: rgba(95,48,128,.08);
      border: 1px solid rgba(95,48,128,.15);
      padding: 4px 12px;
      border-radius: 100px;
    }

    /* ── Origens (view geo/fontes) ── */
    .source-wrap { padding: 14px; }
    .source-row {
      display: flex; align-items: center; justify-content: space-between;
      padding: 10px 0;
      border-bottom: 1px solid rgba(95,48,128,.07);
    }
    .source-row:last-child { border-bottom: none; }
    .source-name { font-size: 13px; font-weight: 600; color: var(--text); }
    .source-meta { font-size: 11px; color: var(--muted); margin-top: 2px; }
    .source-badge {
      background: rgba(34,197,94,.12);
      color: #16a34a;
      border-radius: 8px;
      padding: 3px 8px;
      font-size: 11px; font-weight: 700;
    }
    .source-badge--zero { background: rgba(95,48,128,.07); color: var(--muted); }

    /* ── Nav flutuante glassmorphism ── */
    .nav {
      position: fixed;
      bottom: calc(12px + var(--safe-b));
      left: 50%;
      transform: translateX(-50%);
      z-index: 100;
      display: flex;
      gap: 4px;
      padding: 8px 10px;
      background: rgba(255,255,255,0.78);
      backdrop-filter: blur(32px) saturate(1.8);
      -webkit-backdrop-filter: blur(32px) saturate(1.8);
      border: 1px solid rgba(255,255,255,0.95);
      border-radius: 100px;
      box-shadow:
        0 8px 32px rgba(95,48,128,.18),
        0 2px 8px rgba(0,0,0,.06),
        0 1px 0 rgba(255,255,255,.9) inset;
    }
    .nav-btn {
      display: flex; flex-direction: column; align-items: center; gap: 3px;
      padding: 8px 18px;
      border-radius: 100px;
      border: none; background: transparent;
      cursor: pointer;
      color: var(--muted);
      font-size: 10px; font-weight: 600;
      letter-spacing: 0.02em;
      transition: all .2s ease;
      text-decoration: none;
      white-space: nowrap;
    }
    .nav-btn svg { width: 20px; height: 20px; stroke-width: 2; }
    .nav-btn.active {
      background: var(--purple);
      color: #fff;
      box-shadow: 0 4px 16px rgba(95,48,128,.35);
    }
    .nav-btn:not(.active):hover { background: rgba(95,48,128,.08); color: var(--purple); }

    /* ── Refresh hint ── */
    .refresh-hint {
      text-align: center;
      font-size: 10px; color: var(--muted);
      padding: 8px 0 4px;
      opacity: .6;
    }
  </style>
</head>
<body>

<div class="shell">

  <!-- Topbar -->
  <div class="topbar">
    <div class="topbar__left">
      <img class="topbar__avatar" src="/brand/avatar_e-trindade.png" alt="Embelleze" />
      <div>
        <div class="topbar__name">Andreia</div>
        <span class="topbar__badge">Gestão</span>
      </div>
    </div>
    <img class="topbar__logo" src="/brand/logo_cor_horizontal.png" alt="Instituto Embelleze Trindade" />
    <a href="/api/auth/logout" class="topbar__logout" title="Sair">
      <svg viewBox="0 0 24 24" width="15" height="15" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
        <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/>
      </svg>
    </a>
  </div>

  <!-- Views -->
  <div class="views">

    <!-- ── VIEW: Visão Geral ── -->
    <div class="view active" id="view-home">

      {stalled.length > 0 && (
        <div class="alert-card">
          <div class="alert-head">⚠ {stalled.length} {stalled.length === 1 ? 'contato precisa' : 'contatos precisam'} de atenção</div>
          {stalled.slice(0, 2).map(l => (
            <div class="stall-row">
              <div class="stall-info">
                <div class="stall-name">{l.name ?? l.phone}</div>
                <div class="stall-meta">{l.status} · {l.phone}</div>
              </div>
              <div class="stall-time">{Math.floor(l.horas_parado / 24)}d parado</div>
              <a href={`https://wa.me/55${l.phone.replace(/\D/g,'')}`} target="_blank" class="wa-btn">WA</a>
            </div>
          ))}
        </div>
      )}

      <!-- KPIs -->
      <div class="kpi-grid">
        <div class="glass-card kpi">
          <div class="kpi__num">{summary.movimentados_hoje}</div>
          <div class="kpi__label">Hoje</div>
          <div class="kpi__sub">{summary.total} total</div>
        </div>
        <div class="glass-card kpi">
          <div class={`kpi__num${summary.pix_pago > 0 ? ' kpi__num--green' : ''}`}>{summary.pix_pago}</div>
          <div class="kpi__label">Matrículas</div>
          <div class="kpi__sub">{summary.pix_gerado} pix gerado</div>
        </div>
        <div class="glass-card kpi">
          <div class="kpi__num kpi__num--orange">{taxaConversao}%</div>
          <div class="kpi__label">Conversão</div>
          <div class="kpi__sub">de {summary.total} leads</div>
        </div>
        <div class="glass-card kpi">
          <div class={`kpi__num${stalled.length > 0 ? ' kpi__num--orange' : ''}`}>{stalled.length}</div>
          <div class="kpi__label">Parados +48h</div>
          <div class="kpi__sub">{stalled.length > 0 ? 'precisam contato' : 'tudo em dia'}</div>
        </div>
      </div>

      <!-- Funil -->
      <div class="sec-title">Funil de vendas</div>
      <div class="glass-card funnel-wrap">
        {funnel.map(step => (
          <div class="funnel-row">
            <span class="funnel-lbl">{step.label}</span>
            <div class="funnel-track">
              <div class="funnel-bar" style={`width:${step.percent}%;background:${FUNNEL_COLOR[step.label] ?? '#5f3080'}`}></div>
            </div>
            <span class="funnel-num">{step.count}</span>
          </div>
        ))}
      </div>

      <div class="refresh-hint">Atualiza a cada 60s</div>
    </div>

    <!-- ── VIEW: Geografia ── -->
    <div class="view" id="view-geo">
      <div class="geo-grid">
        <div class="glass-card geo-kpi">
          <div class="geo-kpi__num">{geo.rotasHoje}</div>
          <div class="geo-kpi__lbl">Hoje</div>
          <div class="geo-kpi__sub">
            {geo.variacaoDia > 0 ? `▲ ${geo.variacaoDia}%` : geo.variacaoDia < 0 ? `▼ ${Math.abs(geo.variacaoDia)}%` : '= ontem'}
          </div>
        </div>
        <div class="glass-card geo-kpi">
          <div class="geo-kpi__num">{geo.mediaSemanal}</div>
          <div class="geo-kpi__lbl">Média 7d</div>
          <div class="geo-kpi__sub">{geo.rotasTotais} total</div>
        </div>
        <div class="glass-card geo-kpi">
          <div class={`geo-kpi__num${geo.taxaAceiteGps >= 60 ? '' : ''}`}>{geo.taxaAceiteGps}%</div>
          <div class="geo-kpi__lbl">Aceitaram GPS</div>
          <div class="geo-kpi__sub">{geo.gpsNegado} negaram</div>
        </div>
        <div class="glass-card geo-kpi">
          <div class="geo-kpi__num">{geo.rotasOntem}</div>
          <div class="geo-kpi__lbl">Ontem</div>
          <div class="geo-kpi__sub">abriram o Maps</div>
        </div>
      </div>

      {geo.tendencia7d.some(d => d.count > 0) && (
        <div class="glass-card" style="margin-bottom:12px">
          <div class="bar-chart-wrap">
            <div class="chart-lbl">Google Maps</div>
            <div class="bar-chart">
              {geo.tendencia7d.map(d => (
                <div class="bar-col">
                  <div class="bar-val">{d.count > 0 ? d.count : ''}</div>
                  <div class="bar-track">
                    <div class="bar-fill" style={`height:${d.percent}%`}></div>
                  </div>
                  <div class="bar-lbl">{d.label}</div>
                </div>
              ))}
            </div>
          </div>
        </div>
      )}

      {geo.topBairros.length > 0 && (
        <div class="glass-card">
          <div class="bar-chart-wrap">
            <div class="chart-lbl">Top bairros</div>
          </div>
          <div class="bairros-wrap">
            {geo.topBairros.map(b => (
              <div class="bairro-row">
                <span class="bairro-lbl">{b.bairro}</span>
                <div class="bairro-track"><div class="bairro-fill" style={`width:${b.percent}%`}></div></div>
                <span class="bairro-num">{b.count}</span>
              </div>
            ))}
          </div>
        </div>
      )}
    </div>

    <!-- ── VIEW: Meta ── -->
    <div class="view" id="view-meta">
      <div class="meta-hero glass-card">
        <div class="meta-hero__icon">
          <svg viewBox="0 0 40 24" width="56" height="34" fill="none" xmlns="http://www.w3.org/2000/svg">
            <ellipse cx="8" cy="12" rx="7.5" ry="9.5" stroke="url(#mg)" stroke-width="2.5" fill="none"/>
            <ellipse cx="32" cy="12" rx="7.5" ry="9.5" stroke="url(#mg)" stroke-width="2.5" fill="none"/>
            <path d="M8 2.5C10 5 13 9 16 12c3 3 6 6.5 8 9.5" stroke="url(#mg)" stroke-width="2.5" stroke-linecap="round" fill="none"/>
            <path d="M32 2.5C30 5 27 9 24 12c-3 3-6 6.5-8 9.5" stroke="url(#mg)" stroke-width="2.5" stroke-linecap="round" fill="none"/>
            <defs>
              <linearGradient id="mg" x1="0" y1="0" x2="40" y2="24" gradientUnits="userSpaceOnUse">
                <stop offset="0%" stop-color="#0668E1"/>
                <stop offset="50%" stop-color="#AE3EC9"/>
                <stop offset="100%" stop-color="#FA383E"/>
              </linearGradient>
            </defs>
          </svg>
        </div>
        <div class="meta-hero__text">
          <h2 class="meta-hero__title">Resultados Meta</h2>
          <span class="meta-hero__status">Em implementação</span>
        </div>
      </div>

      <div class="meta-coming">
        <div class="meta-coming__icon">🔗</div>
        <p class="meta-coming__title">Integração em andamento</p>
        <p class="meta-coming__desc">
          As métricas de campanhas — alcance, impressões, cliques, custo por lead e ROAS — serão exibidas aqui assim que a conexão com a API Meta Ads for ativada.
        </p>
        <div class="meta-chips">
          <span class="meta-chip">Alcance</span>
          <span class="meta-chip">CPL</span>
          <span class="meta-chip">ROAS</span>
          <span class="meta-chip">Impressões</span>
          <span class="meta-chip">Cliques</span>
          <span class="meta-chip">Conversões</span>
        </div>
      </div>
    </div>

    <!-- ── VIEW: Fontes ── -->
    <div class="view" id="view-fontes">
      <div class="sec-title">Origem dos leads</div>
      {sources.length > 0 ? (
        <div class="glass-card source-wrap">
          {sources.map(s => (
            <div class="source-row">
              <div>
                <div class="source-name">{s.fonte}</div>
                <div class="source-meta">{s.total} entradas · {s.matriculas} matrículas</div>
              </div>
              <span class={`source-badge${s.taxa === 0 ? ' source-badge--zero' : ''}`}>{s.taxa}%</span>
            </div>
          ))}
        </div>
      ) : (
        <div class="glass-card" style="padding:24px;text-align:center;color:var(--muted);font-size:13px">
          Sem dados de origem ainda
        </div>
      )}
    </div>

  </div><!-- /views -->

  <!-- Nav flutuante -->
  <nav class="nav" role="navigation" aria-label="Navegação principal">
    <button class="nav-btn active" id="btn-home" onclick="switchView('home')">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round">
        <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/>
      </svg>
      Visão Geral
    </button>
    <button class="nav-btn" id="btn-geo" onclick="switchView('geo')">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round">
        <circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/>
      </svg>
      Geografia
    </button>
    <button class="nav-btn" id="btn-fontes" onclick="switchView('fontes')">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round">
        <line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="6" y1="20" x2="6" y2="14"/>
      </svg>
      Fontes
    </button>
    <button class="nav-btn" id="btn-meta" onclick="switchView('meta')">
      <svg viewBox="0 0 24 24" width="20" height="20" fill="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-1 14H9V8h2v8zm4 0h-2V8h2v8z" fill="currentColor" opacity="0"/>
        <path d="M2.5 8.5C3.8 6 6.2 4 9 4c2.1 0 3.8 1 5 2.5C15.2 5 16.9 4 19 4c2.8 0 5.2 2 6.5 4.5" stroke="none"/>
        <!-- Meta "infinity" logo simplificado -->
        <path d="M6.5 12c0-1.4.8-2.5 2-2.5.8 0 1.5.5 2.2 1.5l.8 1.2.8-1.2C13 9.5 13.7 9 14.5 9c1.2 0 2 1.1 2 2.5 0 .8-.3 1.5-.7 2-.7.8-1.5 1.5-2.8 2.5-1.3-1-2.1-1.7-2.8-2.5-.4-.5-.7-1.2-.7-2z" fill="currentColor" stroke="none"/>
        <path d="M4 12c0-2.2 1.1-4 2.5-4 .9 0 1.8.6 2.7 1.8" stroke="currentColor" stroke-width="2" stroke-linecap="round" fill="none"/>
        <path d="M20 12c0-2.2-1.1-4-2.5-4-.9 0-1.8.6-2.7 1.8" stroke="currentColor" stroke-width="2" stroke-linecap="round" fill="none"/>
        <path d="M9.2 9.8C10 11 11 12.5 12 13.8c1-1.3 2-2.8 2.8-4" stroke="currentColor" stroke-width="2" stroke-linecap="round" fill="none"/>
        <ellipse cx="6.5" cy="12" rx="2.5" ry="3.2" stroke="currentColor" stroke-width="2" fill="none"/>
        <ellipse cx="17.5" cy="12" rx="2.5" ry="3.2" stroke="currentColor" stroke-width="2" fill="none"/>
      </svg>
      Meta
    </button>
    <a href="/leads" class="nav-btn">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round">
        <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/>
      </svg>
      Contatos
    </a>
  </nav>

</div>

<script is:inline>
  function switchView(id) {
    document.querySelectorAll('.view').forEach(function(v) { v.classList.remove('active'); });
    document.querySelectorAll('.nav-btn').forEach(function(b) { b.classList.remove('active'); });
    var view = document.getElementById('view-' + id);
    var btn  = document.getElementById('btn-' + id);
    if (view) view.classList.add('active');
    if (btn)  btn.classList.add('active');
  }
  setTimeout(function() { location.reload(); }, 60000);
</script>

</body>
</html>
