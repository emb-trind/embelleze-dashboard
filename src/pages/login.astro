---
import { isAuthenticated } from '../lib/auth';
if (isAuthenticated(Astro.cookies)) return Astro.redirect('/leads');
const error = Astro.url.searchParams.get('error');
---
<!doctype html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Embelleze · Painel</title>
  <link rel="icon" href="/favicon.ico" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    body {
      min-height: 100dvh;
      background: #171018;
      display: flex;
      align-items: center;
      justify-content: center;
      font-family: system-ui, sans-serif;
    }
    .card {
      background: #1e1424;
      border: 1px solid #2e1f3a;
      border-radius: 16px;
      padding: 40px 32px;
      width: 100%;
      max-width: 360px;
      display: flex;
      flex-direction: column;
      gap: 24px;
    }
    .logo {
      display: flex;
      align-items: center;
      gap: 10px;
    }
    .logo img { width: 36px; height: 36px; border-radius: 50%; }
    .logo span { color: #fff; font-size: 16px; font-weight: 700; }
    h1 { color: #fff; font-size: 20px; font-weight: 700; }
    label { color: #a88fc0; font-size: 12px; font-weight: 600; letter-spacing: 0.05em; }
    .password-wrap {
      position: relative;
      margin-top: 6px;
    }
    .password-wrap input {
      width: 100%;
      background: #120d18;
      border: 1.5px solid #2e1f3a;
      border-radius: 8px;
      padding: 12px 42px 12px 14px;
      color: #fff;
      font-size: 15px;
      outline: none;
      font-family: inherit;
      transition: border-color 0.2s;
    }
    .password-wrap input:focus { border-color: #5f3080; }
    .eye-btn {
      position: absolute;
      right: 12px;
      top: 50%;
      transform: translateY(-50%);
      background: none;
      border: none;
      cursor: pointer;
      color: #6b5480;
      padding: 4px;
      width: auto;
      display: flex;
      align-items: center;
      transition: color 0.2s;
    }
    .eye-btn:hover { color: #a88fc0; opacity: 1; }
    button {
      background: #de583d;
      color: #fff;
      border: none;
      border-radius: 8px;
      padding: 14px;
      font-size: 15px;
      font-weight: 700;
      cursor: pointer;
      width: 100%;
      transition: opacity 0.2s;
    }
    button:hover { opacity: 0.88; }
    .error {
      background: #3a1a1a;
      border: 1px solid #6b2020;
      color: #f87171;
      border-radius: 8px;
      padding: 10px 14px;
      font-size: 13px;
    }
  </style>
</head>
<body>
  <div class="card">
    <div class="logo">
      <img src="/brand/avatar_e-trindade.png" alt="Embelleze" />
      <span>Embelleze · Painel</span>
    </div>
    <h1>Entrar no painel</h1>
    {error && <div class="error">Senha incorreta.</div>}
    <form method="POST" action="/api/auth/login">
      <label for="password">Senha</label>
      <div class="password-wrap">
        <input id="password" name="password" type="password" autocomplete="current-password" autofocus required />
        <button type="button" class="eye-btn" id="eye-btn" aria-label="Mostrar senha">
          <svg id="eye-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/>
            <circle cx="12" cy="12" r="3"/>
          </svg>
          <svg id="eye-off-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="display:none">
            <path d="M17.94 17.94A10.07 10.07 0 0112 20c-7 0-11-8-11-8a18.45 18.45 0 015.06-5.94"/>
            <path d="M9.9 4.24A9.12 9.12 0 0112 4c7 0 11 8 11 8a18.5 18.5 0 01-2.16 3.19"/>
            <line x1="1" y1="1" x2="23" y2="23"/>
          </svg>
        </button>
      </div>
      <button type="submit" style="margin-top:16px">Entrar</button>
    </form>
  </div>
  <script>
    const input   = document.getElementById('password')   as HTMLInputElement;
    const btn     = document.getElementById('eye-btn')    as HTMLElement;
    const iconOn  = document.getElementById('eye-icon')   as HTMLElement;
    const iconOff = document.getElementById('eye-off-icon') as HTMLElement;
    btn.addEventListener('click', () => {
      const show = input.type === 'password';
      input.type = show ? 'text' : 'password';
      iconOn.style.display = show ? 'none' : '';
      iconOff.style.display = show ? '' : 'none';
      btn.setAttribute('aria-label', show ? 'Ocultar senha' : 'Mostrar senha');
    });
  </script>
</body>
</html>
